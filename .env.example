APP_ENV=production

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mc_web
DB_USER=mc_web
DB_PASS=

# Self-hosted auth verification defaults
CAPTCHA_EXPIRE_SECONDS=300
CAPTCHA_REFRESH_COOLDOWN_SECONDS=3
CAPTCHA_REFRESH_LIMIT_WINDOW_SECONDS=300
CAPTCHA_REFRESH_LIMIT_COUNT=20
EMAIL_DOMAIN_WHITELIST_ENABLED=1
EMAIL_DOMAIN_WHITELIST=qq.com,foxmail.com,163.com,126.com,gmail.com,outlook.com,hotmail.com,icloud.com,yahoo.com
EMAIL_CODE_EXPIRE_SECONDS=600
EMAIL_CODE_SEND_COOLDOWN_SECONDS=60
EMAIL_CODE_IP_HOURLY_LIMIT=10
EMAIL_CODE_EMAIL_DAILY_LIMIT=10
AUDIT_LOG_STORAGE=mysql

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=StellarWorld

# MUA OAuth
MUA_CLIENT_ID=
MUA_CLIENT_SECRET=
MUA_REDIRECT_URI=

# Internal API auth
INTERNAL_API_HMAC_SECRET=
INTERNAL_API_SIGNATURE_MAX_SKEW_SECONDS=300
LEGACY_INTERNAL_TOKEN_ENABLED=1
SERVER_TOKEN=

# Minecraft / RCON
MC_SERVER_HOST=127.0.0.1
MC_SERVER_PORT=25565
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=
RCON_TIMEOUT=3

# Realtime
REALTIME_ENABLE_PANEL=1
REALTIME_WS_URL=
# Deprecated for frontend delivery: no longer injected into browser JS.
REALTIME_WS_AUTH_TOKEN=
REALTIME_RECONNECT_INTERVAL_MS=3000
WS_STATUS_API_BASE=http://127.0.0.1:3001
WS_STATUS_API_TIMEOUT_MS=2500
WS_STATUS_API_TOKEN=
WS_STATUS_ALLOW_PRIVATE_NETWORK=1
WS_STATUS_ALLOWED_HOSTS=
PUBLIC_STATUS_WS_URL=

# Session
SESSION_COOKIE_SAMESITE=Lax

# Redis
REDIS_ENABLED=1
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_TIMEOUT=2
REDIS_PASSWORD=
REDIS_DB=0

# Optional integrations
SITE_BASE_URL=http://localhost
BAIDU_PUSH_TOKEN=
QQ_BOT_API_URL=
QQ_BOT_API_TOKEN=
QQ_GROUP_ID=0
QQ_BOT_ALLOW_PRIVATE_NETWORK=1
QQ_BOT_ALLOWED_HOSTS=
